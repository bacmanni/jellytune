<?xml version="1.0" encoding="utf-8"?>
<interface>
    <object class="AdwDialog" id="_root">
        <property name="follows-content-size">true</property>
        <child>
            <object class="AdwClamp">
                <property name="maximum-size">500</property>
                <property name="tightening-threshold">700</property>
                <child>
                    <object class="AdwToolbarView">
                        <child type="top">
                            <object class="AdwHeaderBar">
                                <child>
                                    <object class="GtkBox">
                                        <property name="margin-top">6</property>
                                        <property name="margin-bottom">6</property>
                                        <property name="margin-start">6</property>
                                        <property name="margin-end">6</property>
                                        <child>
                                            <object class="GtkImage" id="_albumArt">
                                                <property name="overflow">hidden</property>
                                                <style>
                                                    <class name="icon-dropshadow"/>
                                                    <class name="album-art-small"/>
                                                </style>
                                                <property name="pixel-size">36</property>
                                            </object>
                                        </child>
                                        <child>
                                            <object class="GtkBox">
                                                <property name="orientation">1</property>
                                                <property name="margin-top">6</property>
                                                <property name="margin-start">12</property>
                                                <child>
                                                    <object class="GtkLabel" id="_track">
                                                        <property name="ellipsize">3</property>
                                                        <property name="justify">0</property>
                                                        <property name="halign">1</property>
                                                        <style>
                                                            <class name="title-4"/>
                                                        </style>
                                                    </object>
                                                </child>
                                                <child>
                                                    <object class="GtkLabel" id="_artist">
                                                        <style>
                                                            <class name="dimmed"/>
                                                        </style>
                                                        <property name="ellipsize">3</property>
                                                        <property name="justify">0</property>
                                                        <property name="halign">1</property>
                                                    </object>
                                                </child>
                                            </object>
                                        </child>
                                    </object>
                                </child>
                            </object>
                        </child>
                        <child>
                            <object class="GtkScrolledWindow">
                                <property name="hscrollbar-policy">2</property>
                                <property name="propagate-natural-height">true</property>
                                <child>
                                    <object class="GtkBox">
                                        <property name="margin-bottom">12</property>
                                        <property name="margin-start">12</property>
                                        <property name="margin-end">12</property>
                                        <property name="orientation">1</property>
                                        <child>
                                            <object class="AdwSpinner" id="_spinner">
                                                <property name="margin-top">6</property>
                                                <property name="halign">3</property>
                                                <property name="valign">3</property>
                                                <property name="vexpand">true</property>
                                                <property name="hexpand">true</property>
                                                <property name="width-request">48</property>
                                                <property name="height-request">48</property>
                                            </object>
                                        </child>
                                        <child>
                                            <object class="GtkRevealer" id="_results">
                                                <property name="transition-type">crossfade</property>
                                                <child>
                                                    <object class="GtkBox">
                                                        <property name="orientation">1</property>
                                                        <child>
                                                            <object class="GtkLabel" id="_lyrics">
                                                                <property name="wrap">true</property>
                                                                <property name="margin-top">12</property>
                                                                <property name="halign">1</property>
                                                            </object>
                                                        </child>
                                                    </object>
                                                </child>
                                            </object>
                                        </child>
                                    </object>
                                </child>
                            </object>
                        </child>
                    </object>
                </child>
            </object>
        </child>
    </object>
</interface>